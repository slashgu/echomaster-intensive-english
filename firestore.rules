rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isTeacher() {
      let hasDoc = exists(/databases/$(database)/documents/users/$(request.auth.uid));
      return hasDoc && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function getMyTeacherId() {
      let hasDoc = exists(/databases/$(database)/documents/users/$(request.auth.uid));
      return hasDoc ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teacherId : null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      let data = request.resource.data;
      return hasRequiredFields(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['teacher', 'student'];
    }

    function isValidLesson() {
      let data = request.resource.data;
      return hasRequiredFields(['title', 'authorId', 'createdAt', 'sentenceCount']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.sentenceCount is number && data.sentenceCount > 0 && data.sentenceCount <= 200;
    }

    function isValidSentence() {
      let data = request.resource.data;
      return hasRequiredFields(['text', 'audioBase64', 'orderIndex']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             data.audioBase64 is string && data.audioBase64.size() > 0 && data.audioBase64.size() < 1048576 && // Max 1MB
             data.orderIndex is number && data.orderIndex >= 0 &&
             (!('gapIndexes' in data) || data.gapIndexes is list);
    }

    function isValidProgress() {
      let data = request.resource.data;
      return hasRequiredFields(['userId', 'lessonId', 'mode', 'score', 'completedAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.lessonId is string && data.lessonId.size() > 0 &&
             data.mode in ['dictation', 'gap-fill'] &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.completedAt is timestamp &&
             (!('answers' in data) || data.answers is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read themselves. Teachers can read their students. Anyone can read a teacher (to link).
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        (isTeacher() && resource.data.teacherId == request.auth.uid) ||
        resource.data.role == 'teacher'
      );
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser();
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }

    match /lessons/{lessonId} {
      // Teachers can read their own lessons. Students can read their teacher's lessons.
      allow read: if resource != null && ((isTeacher() && resource.data.authorId == request.auth.uid) || 
                     (!isTeacher() && resource.data.authorId == getMyTeacherId()));
      allow create, update: if isTeacher() && isValidLesson();
      allow delete: if isTeacher() && resource != null && resource.data.authorId == request.auth.uid;

      match /sentences/{sentenceId} {
        // Inherit read access from parent lesson
        allow read: if (isTeacher() && get(/databases/$(database)/documents/lessons/$(lessonId)).data.authorId == request.auth.uid) || 
                       (!isTeacher() && get(/databases/$(database)/documents/lessons/$(lessonId)).data.authorId == getMyTeacherId());
        allow create, update: if isTeacher() && isValidSentence();
        allow delete: if isTeacher();
      }
    }

    match /progress/{progressId} {
      // Students read their own. Teachers read their students'.
      allow read: if resource != null && (isOwner(resource.data.userId) || 
                     (isTeacher() && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.teacherId == request.auth.uid));
      allow create: if isOwner(request.resource.data.userId) && isValidProgress();
      allow update: if resource != null && isOwner(resource.data.userId) && isValidProgress() && request.resource.data.userId == resource.data.userId;
      allow delete: if resource != null && isOwner(resource.data.userId);
    }
  }
}
